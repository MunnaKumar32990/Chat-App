# Render ignore file
# This file tells Render which files to ignore during deployment

# Documentation
*.md
!README.md

# Development files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Environment files (these should be set in Render dashboard)
.env
.env.local
.env.development
.env.test
.env.production
